# TONTO backend provider configuration examples.
# Copy values into your local shell environment; scripts do not auto-load this file.
# Never commit real API keys.

# Provider selection: openai or devexpert.
TONTO_INFERENCE_PROVIDER=openai

# OpenAI provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# DevExpert provider.
DEVEXPERT_API_KEY=
DEVEXPERT_BASE_URL=https://inference.devexpert.io/v1
DEVEXPERT_CHAT_MODEL=mimo-v2.5
DEVEXPERT_STT_MODEL=gpt-4o-mini-transcribe
